// -*- mode: jsonc -*-
// Waybar Configuration
// Based on Omarchy defaults with customizations

{
    "reload_style_on_change": true,
    "layer": "top",
    "position": "top",
    "gtk-layer-shell": true,
    "swap-icon-label": false,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,
    "spacing": 4,
    "modules-left": [
        "clock",
        "custom/weather",
        "custom/pomodoro",
        "custom/wallpaper",
        "group/ai-tray"
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "group/tray-expander",
        "power-profiles-daemon",
        "bluetooth",
        "network",
        "custom/vpn",
        "pulseaudio",
        "custom/cpu",
        "custom/memory",
        "custom/gpu",
        "backlight",
        "battery"
    ],

    "hyprland/workspaces": {
        "swap-icon-label": false
    },

    "clock": {
        "format": "{:L%a %d - %I:%M %p}",
        "tooltip-format": "{:L%d %B %Y}",
        "tooltip": true
    },

    "custom/weather": {
        "interval": 240,
        "exec": "~/.config/waybar/scripts/weather.sh",
        "return-type": "json",
        "format": "{}",
        "tooltip": true
    },

    "custom/pomodoro": {
        "exec": "~/.config/waybar/scripts/pomodoro-status.sh",
        "interval": 1,
        "on-click": "~/.config/waybar/scripts/pomodoro-control.sh start",
        "on-click-right": "~/.config/waybar/scripts/pomodoro-control.sh reset",
        "on-click-backward": "~/.config/waybar/scripts/pomodoro-control.sh pause",
        "on-click-forward": "~/.config/waybar/scripts/pomodoro-control.sh pause",
        "return-type": "text"
    },

    "custom/wallpaper": {
        "format": "ˇ░Şë",
        "on-click": "~/.config/waybar/scripts/wallpaper-next.sh",
        "tooltip-format": "Change Wallpaper\n\nClick to cycle to next wallpaper"
    },

    "custom/codex-usage": {
        "exec": "~/.config/waybar/scripts/codex-usage-simple.py --waybar --format '{icon_plain} {pct}%'",
        "return-type": "json",
        "interval": 120,
        "format": "{}",
        "tooltip": true
    },

    "custom/copilot-usage": {
        "exec": "~/.config/waybar/scripts/copilot-usage-simple.py --waybar --format '{icon_plain} {pct}%'",
        "return-type": "json",
        "interval": 60,
        "format": "{}",
        "tooltip": true
    },

    "custom/opencode-usage": {
        "exec": "~/.config/waybar/scripts/opencode-usage-simple.py --waybar",
        "return-type": "json",
        "interval": 120,
        "format": "{}",
        "tooltip": true
    },

    "custom/claude-usage": {
        "exec": "~/.config/waybar/scripts/claude-usage-simple.py --waybar --format '{icon_plain} {pct}%'",
        "return-type": "json",
        "interval": 120,
        "format": "{}",
        "tooltip": true
    },

    "custom/cpu": {
        "exec": "~/.config/waybar/scripts/cpu-info.sh",
        "return-type": "json",
        "interval": 2,
        "format": "{}",
        "tooltip": true
    },

    "custom/memory": {
        "exec": "~/.config/waybar/scripts/memory-info.sh",
        "return-type": "json",
        "interval": 2,
        "format": "{}",
        "tooltip": true
    },

    "custom/gpu": {
        "exec": "~/.config/waybar/scripts/gpu-info.sh",
        "return-type": "json",
        "interval": 2,
        "format": "{}",
        "tooltip": true
    },

    "backlight": {
        "device": "acpi_video0",
        "format": "{icon} {percent}%",
        "format-icons": ["ˇ░ŤĹ", "ˇ░Ťĺ", "ˇ░Ťô", "ˇ░Ťö", "ˇ░ŤĽ"],
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip": true,
        "tooltip-format": "Brightness: {percent}%"
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-full": "{capacity}% {icon}",
        "format-charging": "{capacity}% ´çŽ",
        "format-plugged": "{capacity}% ´çŽ",
        "format-alt": "{time} {icon}",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },

    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "´âž",
            "performance": "´âž",
            "balanced": "´ëÄ",
            "power-saver": "´üČ"
        }
    },

    "bluetooth": {
        "format": "´Őö",
        "format-disabled": "  ",
        "format-connected": "ˇ░é▒",
        "format-no-controller": "",
        "tooltip-format": "Devices connected: {num_connections}",
        "tooltip-format-connected": "{controller_alias}\n\nConnected: {num_connections}\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}: {device_battery_percentage}%"
    },

    "network": {
        "format-icons": ["ˇ░Ą»", "ˇ░Ąč", "ˇ░Ąó", "ˇ░Ąą", "ˇ░ĄĘ"],
        "format": "{icon}",
        "format-wifi": "{icon}",
        "format-ethernet": "ˇ░Çé",
        "format-disconnected": "ˇ░Ą«",
        "tooltip-format-wifi": "{essid} ({frequency} GHz)",
        "tooltip-format-ethernet": "Connected",
        "tooltip-format-disconnected": "Disconnected",
        "interval": 3,
        "scriptspacing": 1
    },

    "custom/vpn": {
        "exec": "~/.config/waybar/scripts/vpn-status.sh",
        "return-type": "json",
        "interval": 2,
        "format": "{}",
        "tooltip": true
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": " ˇ░ľü 0% ",
        "format-icons": {
            "headphone": " ´Çą ",
            "hands-free": " ´Çą ",
            "headset": " ´Çą ",
            "phone": " ´éĽ ",
            "portable": " ´éĽ ",
            "car": " ´ć╣ ",
            "default": [" ´ÇŽ ", " ´Çž ", " ´ÇĘ "]
        },
        "tooltip": true,
        "tooltip-format": "Volume: {volume}%"
    },

    "tray": {
        "icon-size": 12,
        "spacing": 17
    },

    "group/tray-expander": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 600,
            "children-class": "tray-group-item"
        },
        "modules": ["custom/expand-icon", "tray"]
    },

    "custom/expand-icon": {
        "format": "ÔŚÇ",
        "class": "expand-icon"
    },

    "group/ai-tray": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 600,
            "children-class": "ai-tray-item"
        },
        "modules": [
            "custom/ai-expand-icon",
            "custom/opencode-usage",
            "custom/claude-usage",
            "custom/codex-usage",
            "custom/copilot-usage"
        ]
    },

    "custom/ai-expand-icon": {
        "format": "ţŞŹ",
        "class": "ai-expand-icon",
        "tooltip-format": "AI Services"
    },

    "hyprland/window": {
        "swap-icon-label": false
    },

    "hyprland/language": {
        "format": "{long}"
    },

    "keyboard-state": {
        "numlock": false,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "´Çú",
            "unlocked": "´éť"
        }
    }
}
